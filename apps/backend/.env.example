# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
# Format: postgresql://username:password@host:port/database
# Example: postgresql://postgres:tasteofalohadb@localhost:5432/taste_of_aloha
DATABASE_URL=postgresql://postgres:tasteofalohadb@localhost:5432/taste_of_aloha

# JWT Configuration (if using)
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h

# Prisma Setup:
# - Run migrations: npx prisma migrate dev
# - Generate client: npx prisma generate
# - Add menu items: npm run seed:menu