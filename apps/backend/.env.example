# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
# Format: postgresql://username:password@host:port/database
# Example: postgresql://<db_user>:<db_password>@<db_host>:<db_port>/<db_name>
DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:<db_port>/<db_name>

# Docker Compose development (use when running via docker compose up):
# DATABASE_URL=postgresql://<docker_db_user>:<docker_db_password>@<docker_db_host>:<docker_db_port>/<docker_db_name>

# Optional Prisma build-time fallback vars.
# Used only when DATABASE_URL is not set, for example during `npm run vercel-build`.
PRISMA_FALLBACK_DB_USER=<fallback_db_user>
PRISMA_FALLBACK_DB_PASSWORD=<fallback_db_password>
PRISMA_FALLBACK_DB_HOST=<fallback_db_host>
PRISMA_FALLBACK_DB_PORT=<fallback_db_port>
PRISMA_FALLBACK_DB_NAME=<fallback_db_name>

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h

# Prisma Setup:
# 1. Ensure postgres container is running: docker compose up -d postgres
# - Run migrations: npx prisma migrate dev
# - Generate client: npx prisma generate
# - Add menu items: npm run seed:menu