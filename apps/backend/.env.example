# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration (required for Prisma ORM)
# Local development (without Docker):
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/taste_of_aloha

# Docker Compose development (use when running via docker-compose up):
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/taste_of_aloha

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h