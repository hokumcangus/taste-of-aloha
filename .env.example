# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# ─────────────────────────────────────────────────────
# DATABASE (Required — used by Prisma ORM)
# ─────────────────────────────────────────────────────
# Local development (without Docker):
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/taste_of_aloha

# Docker Compose development (use this when running via docker-compose up):
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/taste_of_aloha

# ─────────────────────────────────────────────────────
# BACKEND
# ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────────────
# FRONTEND
# ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000

# Optional: Email Service (for order notifications)
# SENDGRID_API_KEY=your_sendgrid_key
# EMAIL_FROM=noreply@tasteofalohafood.com

# Optional: SMS Service (for order notifications)
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_PHONE_NUMBER=+1234567890

# Optional: Payment Processing
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: File Storage
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_S3_BUCKET=taste-of-aloha-images
# AWS_REGION=us-west-2
