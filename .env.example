# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# Database Configuration (Docker Compose uses these to initialize Postgres)
DB_USER=<db_user>
DB_PASSWORD=<db_password>
DB_NAME=<db_name>
PORT=5432

# Backend Configuration
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────────────
# FRONTEND
# ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000

# Prisma Setup Guide:
# 1. Ensure postgres container is running: docker-compose up -d postgres
# 2. Clear stale session DATABASE_URL: Remove-Item Env:DATABASE_URL -ErrorAction SilentlyContinue
# 3. Run migrations: cd apps/backend && npx prisma migrate dev
# 4. Seed data: npm run seed:menu
# 5. Start backend: node index.js or npm run dev

# Optional: Email Service (for order notifications)
# SENDGRID_API_KEY=<sendgrid_api_key>
# EMAIL_FROM=<email_from_address>

# Optional: SMS Service (for order notifications)
# TWILIO_ACCOUNT_SID=<twilio_account_sid>
# TWILIO_AUTH_TOKEN=<twilio_auth_token>
# TWILIO_PHONE_NUMBER=<twilio_phone_number>

# Optional: Payment Processing
# STRIPE_SECRET_KEY=<stripe_secret_key>
# STRIPE_PUBLISHABLE_KEY=<stripe_publishable_key>

# Optional: File Storage
# AWS_ACCESS_KEY_ID=<aws_access_key_id>
# AWS_SECRET_ACCESS_KEY=<aws_secret_access_key>
# AWS_S3_BUCKET=<aws_s3_bucket>
# AWS_REGION=<aws_region>
