# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# Database Configuration (Docker Compose uses these to initialize Postgres)
DB_USER=postgres
DB_PASSWORD=tasteofalohadb
DB_NAME=taste_of_aloha
PORT=5432

# Backend Configuration
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Frontend Configuration
VITE_API_URL=http://localhost:3000

# Prisma Setup Guide:
# 1. Ensure postgres container is running: docker-compose up -d postgres
# 2. Clear stale session DATABASE_URL: Remove-Item Env:DATABASE_URL -ErrorAction SilentlyContinue
# 3. Run migrations: cd apps/backend && npx prisma migrate dev
# 4. Seed data: npm run seed:menu
# 5. Start backend: node index.js or npm run dev

# Optional: Email Service (for order notifications)
# SENDGRID_API_KEY=your_sendgrid_key
# EMAIL_FROM=noreply@tasteofalohafood.com

# Optional: SMS Service (for order notifications)
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_PHONE_NUMBER=+1234567890

# Optional: Payment Processing
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: File Storage
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_S3_BUCKET=taste-of-aloha-images
# AWS_REGION=us-west-2
